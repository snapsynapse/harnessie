# Baseline (portfolio Repo Standards, all-tier)
.DS_Store
.env
.env.*
.vercel
node_modules/
__pycache__/
*.pyc
.vscode/
.idea/
dist/
build/
.venv/
venv/
.claude/
handoffs/
working/

# Python caches (additive to baseline)
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Harnessie run output: per-run journals, proofs, workspaces (never committed)
runs/
workspace/

# Secrets: keys live in env vars, never in the repo
*.key

# Session-local research scratch (lej-pp-search)
.perplexity-research/

# Local agent-runtime wrappers: never staged without an explicit operator decision
.agents/
.codex/

# Private roadmap: operator-only planning notes (unreleased scope, portfolio
# integration candidates not yet ready to name publicly). Sibling to the
# tracked ROADMAP.md; promote an item to the public file only after a scrub
# pass. Never referenced from any tracked file beyond this comment.
ROADMAP-PRIVATE.md
